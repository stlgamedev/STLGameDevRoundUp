				    <!-- App Configuration -->
<script src="libraries.min.js"></script>
<script src="app.min.js"></script>

				    <!-- Global site tag (gtag.js) - Google Analytics -->
				    <script>
				        window.ga = window.ga || function () {
				            (ga.q = ga.q || []).push(arguments)
				        };
				        ga.l = +new Date;
				        ga('create', 'UA-2470786-1', 'auto');
				        ga('require', 'eventTracker');
				        ga('require', 'urlChangeTracker');
				        ga('require', 'outboundLinkTracker');
				        ga('require', 'urlChangeTracker');
				        ga('send', 'pageview');
				    </script>
				    <script async src="https://www.google-analytics.com/analytics.js"></script>
				    <script async src="js/libraries/autotrack.js"></script>

				    <script>
				        // Global error handler.
				        window.onerror = function (msg, url, line, col, error) {
				            var str = msg.toLowerCase();

				            // If angularjs throws a modulerr, it usually means the app will not load so we
				            // need to redirect to the maintenance page.
				            if (str.indexOf('[$injector:modulerr]') > 0) {
				                window.location.href = 'https://mohistory.org/maintenance.html';
				            } else {
				                var message = [
				                    'Message: ' + msg,
				                    'URL: ' + url,
				                    'Line: ' + (lineNo || 'NA'),
				                    'Column: ' + (columnNo || 'NA'),
				                    'Error object: ' + JSON.stringify(error)
				                ].join(' - ');

				                console.error(message);
				            }
				            var suppressErrorAlert = true;
				            // If you return true, then error alerts (like in older versions of
				            // Internet Explorer) will be suppressed.
				            return suppressErrorAlert;
				        };
				    </script>
				    <!--<![endif]-->
