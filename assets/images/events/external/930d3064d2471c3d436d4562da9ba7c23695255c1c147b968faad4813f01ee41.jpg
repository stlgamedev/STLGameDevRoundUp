	<!-- Organization -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Organization",
			"url": "https://mohistory.org",
		        "name": "Missouri Historical Society",
			"logo": "http://api.mohistory.org/iiif/webimages/Mohistory.org/defaults/MHSstackedcolor.jpg/full/1920,/0/default.jpg",
			"contactPoint": [
				{ "@type": "ContactPoint",
					"telephone": "+1-314-746-4599",
					"contactType": "customer service"
				}
			],
			"sameAs": [
				"https://www.facebook.com/mohistorymuseum/",
				"https://twitter.com/mohistorymuseum",
			        "https://instagram.com/mohistorymuseum"
			]
	  	}
	</script>

	<!-- Website Search -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"url": "https://mohistory.org/",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://mohistory.org/search?text={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		}
	</script>
