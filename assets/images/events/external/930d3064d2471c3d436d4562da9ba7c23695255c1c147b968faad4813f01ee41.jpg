		    class="animated fadeIn" id="top-of-body">
        <script type="text/javascript">
      		if (window.location.href == "http://mohistory.org/museum") {
            var axel = Math.random()+"";
            var a = axel * 10000000000000;
            document.write('<img style="height:1px;width:1px" src="https://pubads.g.doubleclick.net/activity;xsp=4607284;ord='+ a +'?" width=1 height=1 border=0>');
      		}
          else if (window.location.href == "http://mohistory.org/memorial") {
            var axel = Math.random()+"";
            var a = axel * 10000000000000;
            document.write('<img style="height:1px;width:1px" src="https://pubads.g.doubleclick.net/activity;xsp=4607599;ord='+ a +'?" width=1 height=1 border=0>');
          }
          else if (window.location.href == "http://mohistory.org/society")  {
            var axel = Math.random()+"";
            var a = axel * 10000000000000;
            document.write('<img style="height:1px;width:1px" src="https://pubads.g.doubleclick.net/activity;xsp=4607596;ord='+ a +'?" width=1 height=1 border=0>');
          }
        </script>
